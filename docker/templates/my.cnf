[mysqld]
basedir=/usr
datadir=/home/container/database
socket=/home/container/run/mariadb/mariadb.sock
pid-file=/home/container/run/mariadb/mariadb.pid
port=3306
bind-address=127.0.0.1
skip-name-resolve
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci
max_allowed_packet=64M
tmpdir=/home/container/tmp

[client]
socket=/home/container/run/mariadb/mariadb.sock
port=3306

[mariadb-install-db]
basedir=/usr
datadir=/home/container/database
